{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml",
      "status": 200,
      "headers": {
        "Content-Type": "application/xml",
        "Cache-Control": "public, max-age=3600"
      }
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt",
      "status": 200,
      "headers": {
        "Content-Type": "text/plain"
      }
    },
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/login",
      "dest": "/login.html"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard.html"
    },
    {
      "src": "/tour-details",
      "dest": "/tour-details.html"
    },
    {
      "src": "/rate",
      "dest": "/rate.html"
    },
    {
      "src": "/pay",
      "dest": "/pay.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
